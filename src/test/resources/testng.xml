<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Enuygun Flight Search Suite" parallel="none">

    <!-- Listeners are registered via maven-surefire-plugin <properties> in pom.xml.
         That covers both "mvn test" (suite) and "mvn test -Dtest=..." (direct class)
         runs. Declaring them here too would cause TestNG duplicate-listener warnings. -->

    <!-- ═══ Chrome ═══ -->
    <test name="Chrome - Flight Search">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.FlightSearchTest"/>
        </classes>
    </test>

    <test name="Chrome - Price Sorting">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.PriceSortingTest"/>
        </classes>
    </test>

    <test name="Chrome - Critical Path">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.CriticalPathTest"/>
        </classes>
    </test>

